{
  "name": "jinro-back",
  "version": "0.1.0",
  "private": true,
  "description": "진로나침반 백엔드 — 커리어넷 프록시 · AI 진로상담(SSE) · PDF 리포트",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev": "tsx watch src/main.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "mock:careernet": "tsx tools/mock-careernet.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:int": "vitest run test/integration --no-file-parallelism",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.41.0",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.0.0",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.6.0",
    "nestjs-pino": "^4.4.0",
    "opossum": "^8.4.0",
    "p-retry": "^6.2.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "playwright": "^1.50.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@swc/core": "^1.11.0",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/opossum": "^8.1.8",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.0",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.0"
  }
}
