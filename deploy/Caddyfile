# Caddy — 자동 HTTPS(Let's Encrypt). DNS A레코드(www.jinro.it.kr → 서버IP)와
# 보안그룹 인바운드 80,443 개방이 선행되어야 인증서가 자동 발급됩니다.

www.jinro.it.kr {
	encode zstd gzip
	# SSE(AI 토큰/알림 스트림) 그대로 흘려보내기 — Caddy는 text/event-stream을 자동 flush.
	reverse_proxy frontend:80
}

# 루트 도메인으로 들어오면 www로 통일(인증서도 함께 발급됨).
jinro.it.kr {
	redir https://www.jinro.it.kr{uri} permanent
}
